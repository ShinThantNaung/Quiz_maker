# ── Production (Vercel) — REQUIRED ────────────────────────────────────────
# Turso (hosted libSQL). Create a database, then read the values from the CLI:
#   turso db show <db> --url        ->  TURSO_DATABASE_URL   (libsql://…)
#   turso db tokens create <db>     ->  TURSO_AUTH_TOKEN
# Set BOTH in your Vercel project's Environment Variables (all environments).
TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── Local development ─────────────────────────────────────────────────────
# Run `turso dev` (a local libSQL server) and use the URL it prints; no token:
#   TURSO_DATABASE_URL="http://127.0.0.1:8080"
# Or point at a separate Turso "dev" database so you don't touch production.
#
# DATABASE_URL is only used by the Prisma CLI (migrate/studio) against a local file.
DATABASE_URL="file:./dev.db"
